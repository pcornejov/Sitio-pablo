---
import WhatsAppIcon from "./WhatsAppIcon.astro";

const waMessage = encodeURIComponent(
  "Hola Pablo, vi tu sitio web y me interesa conversar sobre un proyecto 👋",
);
---

<section class="contact" id="contacto">
  <div class="container">
    <div class="contact-card corner-brackets">
      <span class="eyebrow">Contacto</span>
      <h2>Hablemos de tu proyecto</h2>
      <p>
        Cuéntame qué necesitas: una página web, una tienda online o un sistema a medida, y
        conversemos sin compromiso.
      </p>
      <div class="contact-icons">
        <a
          class="icon-btn icon-email"
          href="mailto:pablo.cornejo.v@gmail.com"
          aria-label="Escríbeme un correo a pablo.cornejo.v@gmail.com"
          data-cta="contacto-email"
        >
          <span class="icon-circle">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
                d="m22 6-10 7L2 6"
              ></path></svg
            >
          </span>
          <span class="icon-label">Email</span>
        </a>
        <a
          class="icon-btn icon-whatsapp"
          href={`https://wa.me/56957591164?text=${waMessage}`}
          target="_blank"
          rel="noopener"
          aria-label="Escríbeme por WhatsApp al +56 9 5759 1164"
          data-cta="contacto-whatsapp"
        >
          <span class="icon-circle">
            <WhatsAppIcon size={26} />
          </span>
          <span class="icon-label">WhatsApp</span>
        </a>
        <a
          class="icon-btn icon-linkedin"
          href="https://www.linkedin.com/in/pablo-cornejo-villarroel-43973a59/"
          target="_blank"
          rel="noopener"
          aria-label="Mi perfil de LinkedIn"
        >
          <span class="icon-circle">
            <svg viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M4.98 3.5C4.98 4.9 3.9 6 2.5 6S0 4.9 0 3.5 1.1 1 2.5 1s2.48 1.1 2.48 2.5zM.5 8.4h4V23h-4V8.4zM8.7 8.4h3.83v2h.05c.53-1 1.84-2.05 3.79-2.05 4.06 0 4.81 2.67 4.81 6.14V23h-4v-6.75c0-1.61-.03-3.68-2.24-3.68-2.25 0-2.6 1.75-2.6 3.56V23h-4V8.4z"
              ></path></svg
            >
          </span>
          <span class="icon-label">LinkedIn</span>
        </a>
      </div>
      <a
        href="mailto:pablo.cornejo.v@gmail.com"
        class="btn btn-primary"
        data-cta="contacto-cotizar">Cotizar proyecto</a
      >

      <details class="contact-form-toggle">
        <summary>O escríbeme un mensaje directo</summary>
        <form id="contact-form" class="contact-form">
          <label>
            <span>Tu nombre</span>
            <input type="text" name="nombre" required autocomplete="name" />
          </label>
          <label>
            <span>Tu mensaje</span>
            <textarea name="mensaje" rows="4" required></textarea>
          </label>
          <button type="submit" class="btn btn-secondary" data-cta="contacto-form">
            Abrir mensaje en mi correo
          </button>
          <p class="contact-form-hint">Se abrirá tu aplicación de correo con el mensaje listo para enviar.</p>
        </form>
      </details>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
  }

  .contact-card {
    --bracket-size: 24px;
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-items: center;
  }

  .contact-card p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    max-width: 520px;
  }

  .contact-icons {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-3);
  }

  .icon-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--text-tertiary);
  }

  .icon-btn .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated-2);
    border: 1px solid var(--border-strong);
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.2s ease;
  }

  .icon-btn svg {
    width: 26px;
    height: 26px;
  }

  .icon-linkedin svg {
    fill: currentColor;
  }

  .icon-email svg {
    fill: none;
    stroke: currentColor;
  }

  .icon-btn .icon-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    transition: color 0.15s ease;
  }

  .icon-btn:hover .icon-circle,
  .icon-btn:focus-visible .icon-circle {
    transform: translateY(-4px);
  }

  .icon-btn:hover .icon-label,
  .icon-btn:focus-visible .icon-label {
    color: var(--text-primary);
  }

  .icon-email .icon-circle {
    color: var(--cyan);
  }
  .icon-email:hover .icon-circle,
  .icon-email:focus-visible .icon-circle {
    border-color: var(--cyan);
    box-shadow: 0 0 20px 2px rgba(var(--cyan-rgb), 0.4);
  }

  .icon-whatsapp .icon-circle {
    color: var(--green);
  }
  .icon-whatsapp:hover .icon-circle,
  .icon-whatsapp:focus-visible .icon-circle {
    border-color: var(--green);
    box-shadow: 0 0 20px 2px rgba(var(--green-rgb), 0.4);
  }

  .icon-linkedin .icon-circle {
    color: var(--magenta);
  }
  .icon-linkedin:hover .icon-circle,
  .icon-linkedin:focus-visible .icon-circle {
    border-color: var(--magenta);
    box-shadow: 0 0 20px 2px rgba(var(--magenta-rgb), 0.4);
  }

  .contact-form-toggle {
    width: 100%;
    max-width: 420px;
    margin-top: var(--space-2);
  }

  .contact-form-toggle summary {
    cursor: pointer;
    font-family: var(--font-sub);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    color: var(--cyan);
    text-align: center;
    list-style: none;
    border-bottom: 1px dashed rgba(var(--cyan-rgb), 0.5);
    padding-bottom: 2px;
  }

  .contact-form-toggle summary::-webkit-details-marker {
    display: none;
  }

  .contact-form-toggle summary:hover,
  .contact-form-toggle summary:focus-visible {
    text-shadow: 0 0 8px rgba(var(--cyan-rgb), 0.5);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-4);
    text-align: left;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: var(--bg-elevated-2);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    resize: vertical;
  }

  .contact-form input:focus-visible,
  .contact-form textarea:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 2px;
  }

  .contact-form-hint {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    max-width: none;
    text-align: center;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("#contact-form");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const nombre = (data.get("nombre") as string) ?? "";
    const mensaje = (data.get("mensaje") as string) ?? "";
    const subject = encodeURIComponent(`Consulta desde el sitio · ${nombre}`);
    const body = encodeURIComponent(`${mensaje}\n\n— ${nombre}`);
    window.location.href = `mailto:pablo.cornejo.v@gmail.com?subject=${subject}&body=${body}`;
  });
</script>
