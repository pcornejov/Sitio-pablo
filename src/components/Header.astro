---

<header class="site-header">
  <div class="container header-inner">
    <div class="brand">
      <span class="brand-name">Pablo Cornejo</span>
      <span class="brand-badge">Software &amp; IA</span>
    </div>
    <nav class="nav-links" aria-label="Navegación principal">
      <a href="#servicios">Servicios</a>
      <a href="#contacto">Contacto</a>
    </nav>
    <div class="header-actions">
      <a href="#contacto" class="btn btn-primary btn-sm">Contáctame</a>
    </div>
  </div>
</header>

<nav class="mobile-quicklinks" aria-label="Navegación rápida">
  <a href="#servicios">Servicios</a>
  <span class="dot">·</span>
  <a href="#contacto">Contacto</a>
</nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 17, 32, 0.75);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .brand-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .brand-badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }

  .nav-links {
    display: none;
    gap: var(--space-6);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .nav-links a {
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--text-primary);
    border-bottom-color: var(--accent-cyan);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* ---------- Mobile-only quicklinks bar ---------- */
  .mobile-quicklinks {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-2);
    height: 40px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
  }

  .mobile-quicklinks a {
    padding: 4px 2px;
    transition: color 0.15s ease;
  }

  .mobile-quicklinks a:hover,
  .mobile-quicklinks a:focus-visible {
    color: var(--text-primary);
  }

  .mobile-quicklinks .dot {
    color: var(--text-tertiary);
  }

  @media (min-width: 641px) {
    .nav-links {
      display: flex;
    }

    .mobile-quicklinks {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      height: 64px;
    }
    .brand-badge {
      display: none;
    }
  }
</style>
