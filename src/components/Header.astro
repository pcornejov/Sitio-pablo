---

<header class="site-header">
  <div class="container header-inner">
    <div class="brand">
      Pablo Cornejo <span class="brand-badge">Software &amp; IA</span>
    </div>
    <nav aria-label="Navegación principal">
      <ul class="nav-links">
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#demo">Demo</a></li>
        <li><a href="#por-que">Por qué</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </nav>
    <div class="header-actions">
      <a
        href="https://wa.me/56957591164"
        target="_blank"
        rel="noopener"
        class="btn btn-secondary btn-sm"
      >
        Escribir por WhatsApp
        <span class="visually-hidden">(se abre en una nueva pestaña)</span>
      </a>
      <a href="#contacto" class="btn btn-primary btn-sm">Cotizar proyecto</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    background: rgba(10, 10, 15, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
    gap: var(--space-4);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .brand-badge {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bg-base);
    background: var(--cyan);
    padding: 3px 9px;
    border-radius: 2px;
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-sub);
    font-weight: 600;
    font-size: 1rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-secondary);
    border-bottom: 2px solid transparent;
    padding-bottom: 4px;
    transition:
      color 0.15s,
      border-color 0.15s,
      text-shadow 0.15s;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--text-primary);
    border-color: var(--cyan);
    text-shadow: 0 0 8px rgba(var(--cyan-rgb), 0.6);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }
    .header-actions .btn-secondary {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .header-inner {
      gap: var(--space-2);
    }
    .brand-badge {
      display: none;
    }
  }
</style>
