---
---

<section class="demo" id="demo">
  <div class="container demo-layout">
    <div class="demo-copy">
      <span class="eyebrow">Demo en vivo</span>
      <h2 style="margin-top:12px;">Chatbots que venden por ti, 24/7</h2>
      <p>
        Un cliente escribe, tu chatbot responde, toma el pedido y confirma la compra — sin que
        muevas un dedo. Así se ve una conversación real de principio a fin.
      </p>
    </div>
    <div class="phone">
      <div class="phone-notch"></div>
      <div class="chat-window">
        <div class="chat-header">
          <div class="chat-avatar" aria-hidden="true">🤖</div>
          <div>
            <div class="chat-header-name">Pedidos Bot</div>
            <div class="chat-header-status">● en línea</div>
          </div>
        </div>
        <div class="chat-body">
          <div class="bubble bubble-user" style="animation-delay:.2s">
            Hola! Quiero pedir 2 pizzas familiares
          </div>
          <div class="typing" style="animation-delay:.9s"><span></span><span></span><span
            ></span></div>
          <div class="bubble bubble-bot" style="animation-delay:2.4s">
            ¡Hola! 👋 Con gusto. ¿Qué pizzas te gustaría? Tenemos Pepperoni, Vegetariana y Cuatro
            Quesos.
          </div>
          <div class="bubble bubble-user" style="animation-delay:3s">
            1 Pepperoni y 1 Cuatro Quesos
          </div>
          <div class="typing" style="animation-delay:3.6s"><span></span><span></span><span
            ></span></div>
          <div class="bubble bubble-bot" style="animation-delay:5.1s">
            Perfecto ✅ Pedido: 1 Pepperoni + 1 Cuatro Quesos. Total: $18.990. ¿Confirmas el
            pedido?
          </div>
          <div class="bubble bubble-user" style="animation-delay:5.7s">Sí, confirmo</div>
          <div class="typing" style="animation-delay:6.3s"><span></span><span></span><span
            ></span></div>
          <div class="bubble bubble-bot" style="animation-delay:7.8s">
            🎉 Pedido confirmado #A1042. Tiempo estimado: 35 min. ¡Gracias por tu compra!
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .demo {
    background: var(--bg-base);
  }

  .demo-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-8);
    align-items: center;
  }

  .demo-copy h2 {
    font-size: clamp(1.65rem, 2.6vw + 1rem, 2.35rem);
    font-weight: 900;
    margin-bottom: var(--space-4);
  }

  .demo-copy p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    font-size: 1.03125rem;
    max-width: 480px;
  }

  .phone {
    width: 300px;
    max-width: 100%;
    margin-inline: auto;
    background: #0c0c14;
    border: 2px solid var(--border-strong);
    border-radius: 32px;
    padding: 14px 10px;
    box-shadow:
      0 0 0 1px rgba(var(--cyan-rgb), 0.25),
      0 30px 70px -30px rgba(var(--magenta-rgb), 0.5),
      0 0 60px -10px rgba(var(--cyan-rgb), 0.25);
  }

  .phone-notch {
    width: 70px;
    height: 6px;
    background: #000;
    border-radius: 4px;
    margin: 0 auto 10px;
  }

  .chat-window {
    background: #08080d;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }

  .chat-header {
    background: linear-gradient(90deg, rgba(var(--magenta-rgb), 0.18), rgba(var(--cyan-rgb), 0.18));
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .chat-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #000;
  }

  .chat-header-name {
    font-family: var(--font-sub);
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--text-primary);
  }

  .chat-header-status {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--green);
  }

  .chat-body {
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 360px;
  }

  .bubble {
    max-width: 82%;
    padding: 9px 13px;
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.84375rem;
    line-height: 1.45;
    opacity: 0;
    animation: bubbleIn 0.5s ease forwards;
  }

  @keyframes bubbleIn {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .bubble-user {
    align-self: flex-end;
    background: rgba(var(--cyan-rgb), 0.16);
    border: 1px solid rgba(var(--cyan-rgb), 0.4);
    color: var(--text-primary);
    border-bottom-right-radius: 2px;
  }

  .bubble-bot {
    align-self: flex-start;
    background: rgba(var(--magenta-rgb), 0.14);
    border: 1px solid rgba(var(--magenta-rgb), 0.4);
    color: var(--text-primary);
    border-bottom-left-radius: 2px;
  }

  .typing {
    align-self: flex-start;
    display: inline-flex;
    gap: 4px;
    padding: 10px 14px;
    border-radius: 12px;
    border-bottom-left-radius: 2px;
    background: rgba(var(--magenta-rgb), 0.14);
    border: 1px solid rgba(var(--magenta-rgb), 0.4);
    opacity: 0;
    animation: typingFade 1.6s ease forwards;
  }

  @keyframes typingFade {
    0% {
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    78% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      padding-top: 0;
      padding-bottom: 0;
      height: 0;
      margin: 0;
      overflow: hidden;
    }
  }

  .typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--magenta);
    display: inline-block;
    animation: dotBounce 1s infinite ease-in-out;
  }

  .typing span:nth-child(2) {
    animation-delay: 0.15s;
  }
  .typing span:nth-child(3) {
    animation-delay: 0.3s;
  }

  @keyframes dotBounce {
    0%,
    80%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    40% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }

  @media (max-width: 960px) {
    .demo-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
