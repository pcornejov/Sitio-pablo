---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span>&copy; {year} Pablo Cornejo · Software &amp; IA. Todos los derechos reservados.</span>
    <ul class="footer-links">
      <li><a href="mailto:pablo.cornejo.v@gmail.com">Email</a></li>
      <li>
        <a href="https://wa.me/56957591164" target="_blank" rel="noopener"
          >WhatsApp <span class="visually-hidden">(se abre en una nueva pestaña)</span></a
        >
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/pablo-cornejo-villarroel-43973a59/"
          target="_blank"
          rel="noopener">LinkedIn <span class="visually-hidden">(se abre en una nueva pestaña)</span
          ></a
        >
      </li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-base);
    color: var(--text-tertiary);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .footer-links {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links a {
    text-decoration: none;
    color: var(--text-tertiary);
    transition: color 0.15s;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--cyan);
  }
</style>
