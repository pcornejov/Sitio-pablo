---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-links">
      <a href="mailto:pablo.cornejo.v@gmail.com">pablo.cornejo.v@gmail.com</a>
      <a href="https://wa.me/56957591164" target="_blank" rel="noopener">+56 9 5759 1164</a>
      <a
        href="https://www.linkedin.com/in/pablo-cornejo-villarroel-43973a59/"
        target="_blank"
        rel="noopener">LinkedIn</a
      >
    </div>
    <p>&copy; {year} Pablo Cornejo · Software &amp; IA. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding-block: var(--space-6);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
    text-align: center;
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }

  .footer-links {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--text-secondary);
    border-bottom-color: var(--accent-cyan);
  }
</style>
