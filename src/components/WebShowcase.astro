---
// Single source of truth for the fictional NovaDent mockup's service
// cards, shared by both the laptop and phone views below (the icon SVG
// paths and copy used to be pasted twice and could drift out of sync).
const services = [
  {
    title: "Ortodoncia",
    desc: "Alineadores y frenillos con control mensual.",
    icon: `<path d="M9 3c-2.5 0-4 2-4 4.5 0 4 2 6 2.5 9.5.3 2 .8 4 2 4 1.5 0 1-3 2.5-3s1 3 2.5 3c1.2 0 1.7-2 2-4C17 13.5 19 11.5 19 7.5 19 5 17.5 3 15 3c-1.5 0-2 .8-3 .8S10.5 3 9 3z"></path>`,
  },
  {
    title: "Implantes",
    desc: "Implantes con garantía y seguimiento.",
    icon: `<path d="M12 3l8 3v6c0 4.5-3.5 8-8 9-4.5-1-8-4.5-8-9V6l8-3z"></path>`,
  },
  {
    title: "Estética dental",
    desc: "Blanqueamiento y carillas de porcelana.",
    icon: `<path d="M12 3l2.7 5.7 6.3.8-4.6 4.3 1.2 6.2L12 17l-5.6 3 1.2-6.2L3 9.5l6.3-.8L12 3z"></path>`,
  },
  {
    title: "Urgencias",
    desc: "Atención el mismo día, sin sobrecostos.",
    icon: `<rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M8 3v4M16 3v4M3 10h18"></path>`,
  },
];
---

<section class="webshow" id="muestra">
  <div class="container webshow-layout">
    <div class="webshow-copy">
      <span class="eyebrow">Ejemplo ilustrativo</span>
      <h2 style="margin-top:12px;">Así se ve una web hecha en serio</h2>
      <p>
        Una recreación (no un cliente real) de portada que da confianza, servicios claros y
        reserva de horas online. Y el mismo sitio, impecable también en el celular, que es
        desde donde llegan la mayoría de tus clientes.
      </p>
      <div class="chips">
        <span class="chip">Carga &lt; 1 seg</span>
        <span class="chip">Responsive</span>
        <span class="chip">Reservas online</span>
        <span class="chip">SEO listo</span>
      </div>
      <a href="#contacto" class="btn btn-primary">Quiero una web así</a>
    </div>

    <div class="devices" aria-hidden="true" data-nosnippet>
      <div class="laptop">
        <div class="lap-screen">
          <div class="lap-bar">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
            <div class="lap-url">
              <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"
                ><rect x="4" y="11" width="16" height="9" rx="2"></rect><path d="M8 11V7a4 4 0 0 1 8 0v4"
                ></path></svg
              >
              novadent.cl
            </div>
          </div>
          <div class="lap-view">
            <div class="lap-page nd">
              <header class="nd-nav">
                <span class="nd-brand">Nova<b>Dent</b></span>
                <nav class="nd-links">
                  <span>Servicios</span><span>Equipo</span><span class="nd-cta">Reservar hora</span>
                </nav>
              </header>
              <div class="nd-hero">
                <div>
                  <h3>Tu sonrisa, en buenas manos</h3>
                  <p>
                    Clínica dental con especialistas y tecnología de punta. Reserva tu hora
                    online en menos de un minuto.
                  </p>
                  <span class="nd-btn">Reservar hora online</span>
                </div>
                <div class="nd-hero-img"></div>
              </div>
              <div class="nd-stats">
                <div class="nd-stat"><b>+12</b><span>años de experiencia</span></div>
                <div class="nd-stat"><b>4.9★</b><span>evaluación pacientes</span></div>
                <div class="nd-stat"><b>8.000+</b><span>atenciones realizadas</span></div>
              </div>
              <div class="nd-sec-title">Nuestros servicios</div>
              <div class="nd-cards">
                {
                  services.map((s) => (
                    <div class="nd-card">
                      <div class="nd-ic">
                        <svg viewBox="0 0 24 24" set:html={s.icon} />
                      </div>
                      <h4>{s.title}</h4>
                      <p>{s.desc}</p>
                    </div>
                  ))
                }
              </div>
              <div class="nd-form">
                <h4>Reserva tu hora</h4>
                <div class="nd-field">
                  <span class="nd-label">Nombre completo</span>
                  <div class="nd-input">María Fernández</div>
                </div>
                <div class="nd-row">
                  <div class="nd-field">
                    <span class="nd-label">Fecha</span>
                    <div class="nd-input">24 / 07 / 2026</div>
                  </div>
                  <div class="nd-field">
                    <span class="nd-label">Hora</span>
                    <div class="nd-input">10:30</div>
                  </div>
                </div>
                <div class="nd-field">
                  <span class="nd-label">Especialidad</span>
                  <div class="nd-input">Ortodoncia</div>
                </div>
                <div class="nd-submit">Confirmar reserva ✓</div>
              </div>
              <footer class="nd-foot">
                <span>NovaDent © 2026</span><span>Av. Siempre Viva 742, Chillán</span>
              </footer>
            </div>
            <div class="lap-sb"></div>
          </div>
        </div>
        <div class="lap-base"></div>
      </div>

      <div class="phone">
        <div class="ph-notch"></div>
        <div class="ph-view">
          <div class="ph-page nd">
            <header class="nd-nav">
              <span class="nd-brand">Nova<b>Dent</b></span>
              <nav class="nd-links"><span class="nd-cta">Reservar hora</span></nav>
            </header>
            <div class="nd-hero">
              <div>
                <h3>Tu sonrisa, en buenas manos</h3>
                <p>
                  Clínica dental con especialistas y tecnología de punta. Reserva tu hora online
                  en menos de un minuto.
                </p>
                <span class="nd-btn">Reservar hora online</span>
              </div>
              <div class="nd-hero-img"></div>
            </div>
            <div class="nd-stats">
              <div class="nd-stat"><b>+12</b><span>años exp.</span></div>
              <div class="nd-stat"><b>4.9★</b><span>pacientes</span></div>
              <div class="nd-stat"><b>8.000+</b><span>atenciones</span></div>
            </div>
            <div class="nd-sec-title">Nuestros servicios</div>
            <div class="nd-cards">
              {
                services.slice(0, 2).map((s) => (
                  <div class="nd-card">
                    <div class="nd-ic">
                      <svg viewBox="0 0 24 24" set:html={s.icon} />
                    </div>
                    <h4>{s.title}</h4>
                    <p>{s.desc}</p>
                  </div>
                ))
              }
            </div>
            <div class="nd-form">
              <h4>Reserva tu hora</h4>
              <div class="nd-field">
                <span class="nd-label">Nombre completo</span>
                <div class="nd-input">María Fernández</div>
              </div>
              <div class="nd-field">
                <span class="nd-label">Fecha</span>
                <div class="nd-input">24 / 07 / 2026</div>
              </div>
              <div class="nd-submit">Confirmar reserva ✓</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .webshow {
    background: var(--bg-base);
    overflow: hidden;
  }

  .webshow-layout {
    display: grid;
    grid-template-columns: 1fr 660px;
    gap: var(--space-8);
    align-items: center;
  }

  .webshow-copy h2 {
    font-size: clamp(1.65rem, 2.6vw + 1rem, 2.35rem);
    font-weight: 900;
    margin-bottom: var(--space-4);
  }

  .webshow-copy p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    font-size: 1.03125rem;
    max-width: 480px;
    margin-bottom: var(--space-5);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: var(--space-6);
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid rgba(var(--cyan-rgb), 0.4);
    padding: 6px 12px;
    border-radius: 2px;
  }

  /* ---------- Devices ---------- */
  .devices {
    position: relative;
    height: 560px;
  }

  .laptop {
    position: absolute;
    left: 0;
    top: 30px;
    width: 570px;
    max-width: 100%;
  }

  .lap-screen {
    background: #0c0c14;
    border: 10px solid #1c1c28;
    border-bottom: none;
    border-radius: 14px 14px 0 0;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(var(--cyan-rgb), 0.25),
      0 40px 80px -35px rgba(var(--magenta-rgb), 0.5),
      0 0 60px -10px rgba(var(--cyan-rgb), 0.2);
  }

  .lap-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: #15151f;
    border-bottom: 1px solid var(--border-subtle);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-r {
    background: #ff5f57;
  }
  .dot-y {
    background: #febc2e;
  }
  .dot-g {
    background: #28c840;
  }

  .lap-url {
    flex: 1;
    margin-left: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: #0c0c14;
    border: 1px solid var(--border-subtle);
    border-radius: 20px;
    padding: 3px 12px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }

  .lap-view {
    height: 340px;
    overflow: hidden;
    position: relative;
    background: #f7f9fb;
  }

  .lap-base {
    height: 16px;
    background: linear-gradient(#2a2a38, #16161f);
    border-radius: 0 0 16px 16px;
  }

  .lap-base::after {
    content: "";
    display: block;
    width: 90px;
    height: 5px;
    margin: 0 auto;
    border-radius: 0 0 6px 6px;
    background: #0d0d14;
  }

  /* Laptop auto-scroll: content ≈880px, viewport 340px → max ≈-535px */
  .lap-page {
    animation: lapScroll 16s ease-in-out infinite;
  }

  @keyframes lapScroll {
    0%,
    15% {
      transform: translateY(0);
    }
    33%,
    48% {
      transform: translateY(-270px);
    }
    66%,
    82% {
      transform: translateY(-535px);
    }
    98%,
    100% {
      transform: translateY(0);
    }
  }

  .lap-sb {
    position: absolute;
    right: 3px;
    top: 6px;
    width: 4px;
    height: 80px;
    border-radius: 2px;
    background: rgba(0, 0, 0, 0.28);
    animation: lapSb 16s ease-in-out infinite;
  }

  @keyframes lapSb {
    0%,
    15% {
      transform: translateY(0);
    }
    33%,
    48% {
      transform: translateY(125px);
    }
    66%,
    82% {
      transform: translateY(248px);
    }
    98%,
    100% {
      transform: translateY(0);
    }
  }

  /* ---------- Phone ---------- */
  .phone {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 196px;
    background: #0c0c14;
    border: 8px solid #1c1c28;
    border-radius: 26px;
    overflow: hidden;
    z-index: 2;
    box-shadow:
      0 0 0 1px rgba(var(--green-rgb), 0.3),
      0 30px 60px -25px rgba(0, 0, 0, 0.85);
    animation: phoneFloat 6s ease-in-out infinite;
  }

  @keyframes phoneFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  .ph-notch {
    height: 18px;
    background: #0c0c14;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ph-notch::after {
    content: "";
    width: 56px;
    height: 5px;
    border-radius: 3px;
    background: #1c1c28;
  }

  .ph-view {
    height: 370px;
    overflow: hidden;
    position: relative;
    background: #f7f9fb;
  }

  /* Phone auto-scroll, offset from the laptop's cycle.
     Content ≈980px, viewport 370px → max ≈-610px. If the mockup's copy
     changes length, re-check these translateY values against the new
     content height or the scroll will clip or leave blank space. */
  .ph-page {
    animation: phScroll 16s ease-in-out infinite;
    animation-delay: 1.2s;
  }

  @keyframes phScroll {
    0%,
    17% {
      transform: translateY(0);
    }
    35%,
    50% {
      transform: translateY(-300px);
    }
    68%,
    84% {
      transform: translateY(-580px);
    }
    99%,
    100% {
      transform: translateY(0);
    }
  }

  /* ---------- Fictional site (NovaDent) ---------- */
  .nd {
    background: #f7f9fb;
    color: #1e2a32;
    font-family: var(--font-body);
  }

  .nd-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: #fff;
    border-bottom: 1px solid #e5eaee;
  }

  .nd-brand {
    font-family: var(--font-sub);
    font-weight: 700;
    font-size: 1.05rem;
    color: #0b8f7d;
  }
  .nd-brand b {
    color: #1e2a32;
  }

  .nd-links {
    display: flex;
    gap: 14px;
    font-size: 0.72rem;
    color: #5b6b75;
    align-items: center;
  }

  .nd-cta {
    background: #0b8f7d;
    color: #fff;
    padding: 5px 12px;
    border-radius: 6px;
    font-weight: 600;
  }

  .nd-hero {
    display: flex;
    gap: 18px;
    align-items: center;
    padding: 26px 20px;
  }

  .nd-hero h3 {
    font-family: var(--font-sub);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.1;
    margin-bottom: 8px;
    color: #1e2a32;
  }

  .nd-hero p {
    font-size: 0.8rem;
    color: #5b6b75;
    line-height: 1.45;
    margin-bottom: 12px;
  }

  .nd-btn {
    display: inline-block;
    background: #0b8f7d;
    color: #fff;
    font-weight: 600;
    font-size: 0.78rem;
    padding: 9px 16px;
    border-radius: 8px;
    box-shadow: 0 8px 18px -8px rgba(11, 143, 125, 0.7);
  }

  .nd-hero-img {
    width: 150px;
    height: 110px;
    border-radius: 14px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #d7f3ee, #9adfd2);
    position: relative;
    overflow: hidden;
  }

  .nd-hero-img::after {
    content: "";
    position: absolute;
    right: -18px;
    bottom: -18px;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
  }

  .nd-stats {
    display: flex;
    gap: 10px;
    padding: 0 20px 20px;
  }

  .nd-stat {
    flex: 1;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 10px;
    padding: 10px 8px;
    text-align: center;
  }

  .nd-stat b {
    display: block;
    font-size: 0.95rem;
    color: #0b8f7d;
  }

  .nd-stat span {
    font-size: 0.62rem;
    color: #5b6b75;
  }

  .nd-sec-title {
    padding: 0 20px 10px;
    font-family: var(--font-sub);
    font-weight: 700;
    font-size: 1.05rem;
    color: #1e2a32;
  }

  .nd-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding: 0 20px 22px;
  }

  .nd-card {
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 10px;
    padding: 12px;
  }

  .nd-ic {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: #e2f5f1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }

  .nd-ic svg {
    width: 14px;
    height: 14px;
    stroke: #0b8f7d;
    fill: none;
    stroke-width: 2;
  }

  .nd-card h4 {
    font-size: 0.76rem;
    margin-bottom: 3px;
    color: #1e2a32;
  }

  .nd-card p {
    font-size: 0.65rem;
    color: #5b6b75;
    line-height: 1.4;
  }

  .nd-form {
    margin: 0 20px 22px;
    background: #fff;
    border: 1px solid #e5eaee;
    border-radius: 12px;
    padding: 16px;
  }

  .nd-form h4 {
    font-family: var(--font-sub);
    font-size: 0.95rem;
    margin-bottom: 10px;
    color: #1e2a32;
  }

  .nd-field {
    margin-bottom: 8px;
  }

  .nd-label {
    display: block;
    font-size: 0.62rem;
    color: #5b6b75;
    margin-bottom: 3px;
  }

  .nd-input {
    width: 100%;
    border: 1px solid #dbe3e8;
    border-radius: 7px;
    padding: 7px 9px;
    font-size: 0.7rem;
    color: #1e2a32;
    background: #fbfcfd;
  }

  .nd-row {
    display: flex;
    gap: 8px;
  }

  .nd-row .nd-field {
    flex: 1;
  }

  .nd-submit {
    width: 100%;
    background: #0b8f7d;
    color: #fff;
    border-radius: 8px;
    padding: 9px;
    font-weight: 600;
    font-size: 0.75rem;
    margin-top: 4px;
    text-align: center;
  }

  .nd-foot {
    background: #12232b;
    color: #9db4be;
    font-size: 0.6rem;
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
  }

  /* Phone-adapted overrides */
  .ph-view .nd-nav {
    padding: 10px 12px;
  }
  .ph-view .nd-cta {
    font-size: 0.6rem;
    padding: 4px 9px;
  }
  .ph-view .nd-hero {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 16px 12px;
  }
  .ph-view .nd-hero-img {
    width: 100%;
    height: 64px;
  }
  .ph-view .nd-stats {
    padding: 0 12px 12px;
    gap: 6px;
  }
  .ph-view .nd-stat span {
    font-size: 0.5rem;
  }
  .ph-view .nd-sec-title {
    padding: 0 12px 8px;
    font-size: 0.85rem;
  }
  .ph-view .nd-cards {
    grid-template-columns: 1fr;
    padding: 0 12px 16px;
    gap: 8px;
  }
  .ph-view .nd-form {
    margin: 0 12px 16px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1100px) {
    .webshow-layout {
      grid-template-columns: 1fr 560px;
    }
    .laptop {
      width: 480px;
    }
  }

  @media (max-width: 960px) {
    .webshow-layout {
      grid-template-columns: 1fr;
    }
    .devices {
      height: auto;
      display: flex;
      justify-content: center;
    }
    /* On small screens the visitor is already holding the "responsive
       proof" in their hand — show only the phone mockup, centered. */
    .laptop {
      display: none;
    }
    .phone {
      position: static;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lap-page,
    .ph-page,
    .lap-sb,
    .phone {
      animation: none !important;
    }
  }
</style>
