---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const waMessage = encodeURIComponent("Hola Pablo, vi tu sitio y quiero conversar sobre un proyecto 👋");

const valores = [
  {
    titulo: "Código que dura",
    texto:
      "Prefiero hacerlo bien una vez a estar parchando para siempre. Lo que construyo está pensado para crecer, no para reescribirse en un año.",
  },
  {
    titulo: "Sin desaparecer",
    texto:
      "Reuniones periódicas, avances que puedes ver y un canal directo conmigo. Siempre sabes en qué va tu proyecto.",
  },
  {
    titulo: "Tecnología probada",
    texto:
      "Uso el mismo stack de proyectos bancarios y de gobierno, no experimentos: Node.js, Java, Angular y AWS.",
  },
];

const stack = ["Node.js", "NestJS", "Java", "Angular", "TypeScript", "Python", "AWS", "Docker"];
---

<BaseLayout
  title="Sobre mí · Pablo Cornejo"
  description="Pablo Cornejo, desarrollador de software con +15 años de experiencia en banca, gobierno y fintech. Hoy diseño páginas web, tiendas online y software a medida para empresas y negocios."
>
  <Header />
  <main id="main-content">
    <section class="about">
      <div class="container about-inner">
        <div class="about-head">
          <div class="avatar" aria-hidden="true">PC</div>
          <span class="eyebrow">Sobre mí</span>
          <h1>Hola, soy <span class="accent">Pablo Cornejo</span></h1>
          <p class="about-sub">
            Desarrollador de software con más de 15 años construyendo sistemas para banca,
            gobierno y fintech. Hoy pongo esa misma experiencia al servicio de negocios y
            empresas que necesitan una web, una tienda online o un software bien hecho.
          </p>
        </div>

        <div class="about-story">
          <h2>De los sistemas críticos a tu proyecto</h2>
          <p>
            Durante más de 15 años trabajé en el tipo de software donde un error no es una
            opción: plataformas bancarias, sistemas de gobierno e integraciones fintech, donde la
            seguridad, la estabilidad y los plazos importan de verdad.
          </p>
          <p>
            Con la IA como herramienta de desarrollo pude acortar los tiempos sin bajar ese
            estándar. Eso me permitió abrir mi trabajo a negocios más chicos: los mismos
            criterios de calidad, ahora a un costo y una velocidad que antes solo estaban al
            alcance de las grandes empresas.
          </p>
          <p>
            Hoy diseño y desarrollo páginas web, tiendas online y software a medida para quien
            necesita algo serio, hecho por una persona real que responde y se hace cargo del
            proyecto.
          </p>
        </div>

        <div class="about-values">
          {
            valores.map((v) => (
              <div class="value-card corner-brackets">
                <h3>{v.titulo}</h3>
                <p>{v.texto}</p>
              </div>
            ))
          }
        </div>

        <div class="about-stack">
          <h2>Con qué trabajo</h2>
          <div class="stack-chips">
            {stack.map((t) => <span class="stack-chip">{t}</span>)}
          </div>
        </div>

        <div class="about-ctas">
          <a href="/#contacto" class="btn btn-primary">Conversemos tu proyecto</a>
          <a
            href={`https://wa.me/56957591164?text=${waMessage}`}
            target="_blank"
            rel="noopener"
            class="btn btn-secondary"
            data-cta="about-whatsapp"
          >
            Escríbeme por WhatsApp
            <span class="visually-hidden">(se abre en una nueva pestaña)</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about {
    background: var(--bg-base);
  }

  .about-inner {
    max-width: 820px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .about-head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2rem;
    color: var(--bg-base);
    background: radial-gradient(circle at 35% 30%, var(--cyan), var(--magenta));
    box-shadow:
      0 0 0 1px rgba(var(--cyan-rgb), 0.4),
      0 0 40px -8px rgba(var(--magenta-rgb), 0.6);
    margin-bottom: var(--space-2);
  }

  .about h1 {
    font-size: clamp(2rem, 3.2vw + 1rem, 2.9rem);
    font-weight: 900;
    line-height: 1.15;
  }

  .about h1 .accent {
    color: var(--magenta);
    text-shadow:
      0 0 18px rgba(var(--magenta-rgb), 0.55),
      0 0 42px rgba(var(--magenta-rgb), 0.25);
  }

  .about-sub {
    font-family: var(--font-body);
    color: var(--text-secondary);
    font-size: 1.0625rem;
    max-width: 620px;
  }

  .about-story {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-story h2,
  .about-stack h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.4rem, 2vw + 1rem, 1.85rem);
    margin-bottom: var(--space-2);
  }

  .about-story p {
    font-family: var(--font-body);
    color: var(--text-secondary);
    font-size: 1.03125rem;
    line-height: 1.65;
  }

  .about-values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .value-card {
    --bracket-size: 16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .value-card h3 {
    font-family: var(--font-sub);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--cyan);
  }

  .value-card p {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .stack-chip {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.03em;
    color: var(--green);
    border: 1px solid rgba(var(--green-rgb), 0.35);
    background: rgba(var(--green-rgb), 0.06);
    padding: 7px 14px;
    border-radius: 2px;
  }

  .about-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-2);
  }

  @media (max-width: 720px) {
    .about-values {
      grid-template-columns: 1fr;
    }
  }
</style>
