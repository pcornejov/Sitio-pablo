---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Servicios from "../components/Servicios.astro";
import ChatDemo from "../components/ChatDemo.astro";
import Credibility from "../components/Credibility.astro";
import ComoTrabajo from "../components/ComoTrabajo.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Pablo Cornejo · Desarrollo de Software de Punta a Punta con IA">
  <Header />
  <main id="main-content">
    <Hero />
    <Servicios />
    <ChatDemo />
    <Credibility />
    <ComoTrabajo />
    <Contacto />
  </main>
  <Footer />
  <a
    class="wa-float"
    href="https://wa.me/56957591164"
    target="_blank"
    rel="noopener"
    aria-label="Escríbeme por WhatsApp"
  >
    <svg viewBox="0 0 32 32"
      ><path
        d="M16 3C9.4 3 4 8.4 4 15c0 2.4.7 4.6 1.9 6.5L4 29l7.7-2c1.9 1 4 1.6 6.3 1.6 6.6 0 12-5.4 12-12S22.6 3 16 3Zm0 21.8c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-4.6 1.2 1.2-4.4-.2-.4C5.8 18 5.2 16.5 5.2 15c0-5.9 4.9-10.8 10.8-10.8S26.8 9.1 26.8 15 21.9 24.8 16 24.8Zm5.9-8.1c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.5-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.2 3.3 5.3 4.6.7.3 1.3.5 1.8.6.7.2 1.4.2 1.9.1.6-.1 1.9-.8 2.2-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3Z"
      ></path></svg
    >
  </a>
</BaseLayout>

<style>
  .wa-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 90;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #3dffb0, #17c98a);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 1px rgba(var(--cyan-rgb), 0.4),
      0 10px 26px -6px rgba(0, 0, 0, 0.6),
      0 0 24px 2px rgba(var(--green-rgb), 0.35);
    text-decoration: none;
    transition:
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }

  .wa-float:hover,
  .wa-float:focus-visible {
    transform: scale(1.08);
    box-shadow:
      0 0 0 1px var(--cyan),
      0 10px 26px -6px rgba(0, 0, 0, 0.6),
      0 0 34px 6px rgba(var(--green-rgb), 0.5);
  }

  .wa-float svg {
    width: 30px;
    height: 30px;
    fill: #06110c;
  }
</style>
