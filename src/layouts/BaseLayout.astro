---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title = "Pablo Cornejo · Diseño Web y Software a Medida con IA",
  description = "Diseño páginas web y desarrollo de software a medida con IA para empresas y negocios locales. +15 años de experiencia en banca, gobierno y fintech.",
} = Astro.props;

const siteUrl = "https://www.pablocornejo.cl/";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = "https://www.pablocornejo.cl/og-image.png";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Pablo Cornejo",
  jobTitle: "Desarrollador de software",
  image: ogImage,
  url: siteUrl,
  telephone: "+56957591164",
  email: "pablo.cornejo.v@gmail.com",
  description,
  sameAs: ["https://www.linkedin.com/in/pablo-cornejo-villarroel-43973a59/"],
  makesOffer: [
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Diseño y desarrollo de páginas web",
        areaServed: "CL",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Desarrollo de software a medida",
        areaServed: "CL",
      },
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(personJsonLd)}
    />

    <style is:global set:html={`
      @font-face{font-family:'Orbitron';font-style:normal;font-weight:700;font-display:swap;src:url('${base}/fonts/orbitron-700.woff2') format('woff2');}
      @font-face{font-family:'Orbitron';font-style:normal;font-weight:900;font-display:swap;src:url('${base}/fonts/orbitron-900.woff2') format('woff2');}
      @font-face{font-family:'Rajdhani';font-style:normal;font-weight:600;font-display:swap;src:url('${base}/fonts/rajdhani-600.woff2') format('woff2');}
      @font-face{font-family:'Rajdhani';font-style:normal;font-weight:700;font-display:swap;src:url('${base}/fonts/rajdhani-700.woff2') format('woff2');}
      @font-face{font-family:'Share Tech Mono';font-style:normal;font-weight:400;font-display:swap;src:url('${base}/fonts/share-tech-mono-400.woff2') format('woff2');}
      @font-face{font-family:'Inter';font-style:normal;font-weight:400;font-display:swap;src:url('${base}/fonts/inter-400.woff2') format('woff2');}
      @font-face{font-family:'Inter';font-style:normal;font-weight:600;font-display:swap;src:url('${base}/fonts/inter-600.woff2') format('woff2');}
    `} />
    <script is:inline>
      (function () {
        var reduced =
          window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (!reduced) {
          document.documentElement.classList.add("js-reveal");
        }
      })();
    </script>

    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      type="module"
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "44534d3d3a6b4fe7a20758664bdbafae"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
    <script>
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!prefersReducedMotion && "IntersectionObserver" in window) {
        const revealEls = document.querySelectorAll<HTMLElement>(".reveal");

        if (revealEls.length) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15 },
          );

          revealEls.forEach((el) => observer.observe(el));
        }
      }
    </script>
  </body>
</html>
